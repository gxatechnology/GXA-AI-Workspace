# Existing AI provider (server only)
GEMINI_API_KEY=

# Canonical public application origin; comma-separate trusted origins if required
APP_ORIGIN=https://your-production-domain.example

# Durable database path for this deployment
GXA_DB_FILE=/path/to/durable/db.json

# Required in production to encrypt recoverable webhook signing secrets
PLATFORM_ENCRYPTION_KEY=

# Razorpay server credentials. All three are required to enable checkout.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
